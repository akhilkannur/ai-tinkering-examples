{
  "manifest_version": 3,
  "name": "Agent Architect",
  "version": "1.0.0",
  "description": "Transform messy web text into structured Markdown for AI Agents using local browser AI.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Agent Architect"
  },
  "side_panel": {
    "default_path": "src/panel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
